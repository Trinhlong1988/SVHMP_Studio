        0.1,
        0.3,
        0.0,
        0.2,
        0.1,
        0.3
      ],
      "pause_after_ms": 1500,
      "is_dialogue": false
    },
    {
      "text": "Khải Phong nhíu mắt khẽ một thoáng, Lâu lắm rồi - anh không đi qua cây cầu này.",
