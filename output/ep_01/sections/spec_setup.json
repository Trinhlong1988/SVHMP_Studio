        0.3,
        0.0,
        0.2,
        0.1,
        0.3
      ],
      "pause_after_ms": 1500,
      "is_dialogue": false
    },
    {
      "text": "Bác tài liếc gương chiếu hậu — ánh mắt dừng lại nơi anh trong chốc lát, rồi quay đi như chưa từng nhìn.",
