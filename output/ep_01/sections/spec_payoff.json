        0.35,
        0.05,
        0.35
      ],
      "pause_after_ms": 1500,
      "is_dialogue": false,
      "tempo_factor": 0.95
    },
    {
      "text": "— Cảm ơn cháu nhé, chú xin phép xuống đây. (đoạn này phải thật nhẹ nhàng đang bị gắt như vui vẻ vậy)",
      "emo_vector": [
