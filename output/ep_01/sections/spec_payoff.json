      ],
      "pause_after_ms": 1500,
      "is_dialogue": false,
      "tempo_factor": 0.95
    },
    {
      "text": "chiếc đồng hồ trượt khỏi lòng tay, rơi êm xuống nệm chiếc ghế bỏ trống số bảy, vỏ xà cừ phản chiếu ánh đèn cabin một thoáng.",
      "emo_vector": [
