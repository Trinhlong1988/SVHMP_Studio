        0.35
      ],
      "pause_after_ms": 1500,
      "is_dialogue": true,
      "tempo_factor": 0.95
    },
    {
      "text": "Cô gái khẽ nghiêng đầu nhìn anh.",
      "emo_vector": [
        0.0,
