      "pause_after_ms": 1500,
      "is_dialogue": false,
      "tempo_factor": 0.97
    },
    {
      "text": "Kim đồng hồ đã dừng lại từ rất lâu — đúng vào con số bảy giờ mười phút tối, im lìm bất động, hệt như một pho tượng nhỏ làm bằng kim loại đen.",
      "emo_vector": [
