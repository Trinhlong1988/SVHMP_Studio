      "pause_after_ms": 1500,
      "is_dialogue": false,
      "tempo_factor": 0.92
    },
    {
      "text": "Nhìn xuống ghế cạnh mình, cô thấy chiếc đồng hồ đang nằm đó — vỏ xà cừ, kim chỉ bảy giờ mười.",
      "emo_vector": [
