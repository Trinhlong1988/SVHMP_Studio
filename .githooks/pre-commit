#!/bin/bash
# SVHMP pre-commit hook — R41 HARDLOCK + R-ID conflict guard
# Mr.Long 27/6: CẤM commit EP nếu post_render_gate FAIL
# CMD LEAD 29/6: CẤM commit nếu bible/*.yaml add R{N} đã occupied (em vi phạm 3 lần session 29/6)
# Setup: git config core.hooksPath .githooks

set -e

# === SECTION A: R-ID CONFLICT GUARD (CMD LEAD 29/6) ===
staged_bible=$(git diff --cached --name-only | grep -E '^bible/0[05]_.*\.yaml$' || true)
if [ -n "$staged_bible" ]; then
  echo "=== SVHMP R-ID CONFLICT GUARD ==="
  if ! PYTHONIOENCODING=utf-8 python tools/check_rule_id_free.py --staged; then
    echo ""
    echo "==================================================================="
    echo "✗✗✗ R-ID CONFLICT — COMMIT BLOCKED"
    echo "==================================================================="
    echo "Pick different R{N} ID. Verify free slot: python tools/check_rule_id_free.py <N>"
    echo "KHÔNG dùng --no-verify (Mr.Long lệnh nghiêm cấm sai)."
    exit 1
  fi
fi

# === SECTION C: MASS-REPLACE LOG GUARD (CMD LEAD 29/6) ===
# Detect mass-replace pattern (≥10 instances cùng word→word trong staged diff)
# → require log entry trong RENAME_LOG.md (precedent: Hắc Vỹ Dạ → Hắc Dạ Ký revert silent)
mass_replace=$(git diff --cached --unified=0 | grep -E "^-[^-]" | head -200 | sort | uniq -c | sort -rn | awk '$1 >= 10 {print $0}')
if [ -n "$mass_replace" ]; then
  echo "=== SVHMP MASS-REPLACE GUARD ==="
  echo "Mass-replace pattern detected (≥10 same lines removed):"
  echo "$mass_replace" | head -5
  # Check RENAME_LOG.md has entry today
  today=$(date +%Y-%m-%d)
  if [ ! -f RENAME_LOG.md ] || ! grep -q "$today" RENAME_LOG.md; then
    echo ""
    echo "==================================================================="
    echo "⚠ MASS-REPLACE WITHOUT LOG — please document decision"
    echo "==================================================================="
    echo "Run: python tools/log_rename.py <old> <new> \"reason\""
    echo ""
    echo "(WARN only — commit allowed but document for audit trail)"
  fi
fi

# === SECTION B: R41 POST_RENDER_GATE ===
staged_eps=$(git diff --cached --name-only | grep -E '^output/ep_[0-9]+/episode\.md$' || true)

if [ -z "$staged_eps" ]; then
  exit 0
fi

echo "=== SVHMP R41 PRE-COMMIT GATE ==="
all_pass=true

for ep_file in $staged_eps; do
  ep_num=$(echo "$ep_file" | sed -E 's|output/ep_0*([0-9]+)/.*|\1|')
  result=$(PYTHONIOENCODING=utf-8 python tools/post_render_gate.py --ep $ep_num 2>&1 | grep "Total:" | sed 's/.*Total: //')
  if [[ "$result" =~ "0 FAIL" ]] || [[ "$result" =~ "0FAIL" ]]; then
    echo "  ✓ EP$(printf "%02d" $ep_num): $result"
  else
    echo "  ✗ EP$(printf "%02d" $ep_num): $result"
    echo "    DETAILS:"
    PYTHONIOENCODING=utf-8 python tools/post_render_gate.py --ep $ep_num 2>&1 | grep "✗" | head -5 | sed 's/^/      /'
    all_pass=false
  fi
done

if [ "$all_pass" = false ]; then
  echo ""
  echo "==================================================================="
  echo "✗✗✗ R41 HARDLOCK — COMMIT BLOCKED"
  echo "==================================================================="
  echo "Fix EP FAIL trên + git add lại + commit. KHÔNG dùng --no-verify."
  exit 1
fi

echo ""
echo "✓ R41 GATE PASS — commit OK"
exit 0
