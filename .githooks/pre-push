#!/bin/sh
# capture pre-push ref-list (stdin) mot lan de dua cho promotion_guard + git-lfs
STDIN_DATA=$(cat)

# git-lfs optional (may Admin khong co lfs) — skip neu thieu, KHONG chan push
if command -v git-lfs >/dev/null 2>&1; then printf '%s\n' "$STDIN_DATA" | git lfs pre-push "$@" || exit $?; fi

PY="C:/Users/Admin/index-tts/.venv/Scripts/python.exe"
[ -x "$PY" ] || PY=python

# --- PROMOTION GUARD (PACK1 hard-gate HANH VI) — chan tu-lock/tu-tag khong uy quyen ---
echo "[pre-push] promotion guard..."
printf '%s\n' "$STDIN_DATA" | "$PY" tools/promotion_guard.py || { echo "[pre-push] PROMOTION GUARD BLOCK -> push BI CHAN."; exit 1; }

# --- SVHMP CI GATE (R211, Boss 2/7) — chan push neu registry/test FAIL ---
echo "[pre-push] SVHMP CI gate..."
"$PY" tools/ci_gate.py || { echo "[pre-push] CI GATE FAIL -> push BI CHAN."; exit 1; }
exit 0
