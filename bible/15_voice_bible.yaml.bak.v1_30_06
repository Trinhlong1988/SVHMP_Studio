# ============================================================
# DIALOGUE ACTING RULES (per Mr.Long docx v6)
# ============================================================
# Người già / trẻ / mẹ / bố KHÔNG đọc giống nhau

dialog_acting:
  elder:
    pace: slower (×0.92)
    breathiness: medium
    vibrato: subtle
    pitch_variance: low
    notes: "Câu ngắn hơn, có pause giữa câu. Hơi thở rõ nhẹ."

  child:
    pace: faster (×1.05)
    brightness: higher (energy +0.10)
    pitch_semitones: +2 vs adult baseline
    notes: "Câu rời, đôi khi reset giữa câu. ONLY trong flashback có voice trẻ con."

  mother:
    warmth: high (warmth +0.15)
    pace: normal
    pitch_variance: medium-high
    notes: "Câu gắt mềm — yêu nhưng kiên định. Tránh 'syrupy'."

  father:
    authority: medium (authority +0.20)
    pace: slower (×0.95)
    breathiness: low
    pitch_variance: low
    notes: "Câu ngắn dứt khoát. Tránh nâng cao giọng kết câu."

  young_woman:
    pace: normal
    pitch_variance: medium-high
    energy: 0.30
    notes: "Câu mềm nhưng KHÔNG yếu. Tránh whisper-y."

  young_man:
    pace: normal
    pitch_semitones: 0 (baseline male)
    energy: 0.30
    notes: "Câu trầm tĩnh. Tránh 'cool guy' style — quá flat."

  elder_woman_grandmother:
    pace: slower (×0.88)
    warmth: high (warmth +0.15)
    breathiness: medium
    pitch_semitones: -1
    notes: "Câu chậm rãi, ấm. Có pause thoughtful. Tránh whispy."

  elder_man_grandfather:
    pace: slower (×0.88)
    gravitas: high (authority +0.25)
    pitch_semitones: -2
    notes: "Câu trầm vang. Pause trước câu key. Tránh sermonizing."

# ============================================================
# EMOTION SCALE MAP (per docx v6 — chuẩn intensity vocabulary)
# ============================================================
# Mỗi number trên scale = 1 label cụ thể. Generator/TTS đồng bộ vocabulary.

emotion_scale:
  0.00: "silent"           # không có emotion (room tone only, no narration emotion)
  0.20: "almost_flat"      # baseline narrator, gentle
  0.40: "reflective"       # contemplative, slight melancholy
  0.60: "emotional"        # tearing up, voice slight tremor
  0.80: "choking"          # voice broken at edges (beat_4 peak REGRET LINE)
  1.00: "crying"           # NOT used — too dramatic, soul drift
                          # CAP intensity at 0.85 cho mọi production render

scale_mapping_to_presets:
  curious:        0.40 (reflective)
  uneasy:         0.50
  empathy:        0.55
  regret:         0.70 (emotional)
  regret_climax:  0.80 (choking) — ONLY beat_4 PHẦN 3 dòng 3-5 câu
  regret_fading:  0.55
  lingering:      0.45
  lingering_extended: 0.40
  bac_tai_speech: 0.20 (almost_flat)
  passenger_regret: 0.75
  child_voiceover_flashback: 0.50

intensity_per_ep_range_apply (load bible/09_emotion_intensity):
  ep_1_10:    base × 0.85   # khán giả mới, không đẩy quá
  ep_11_30:   base × 1.00
  ep_31_60:   base × 1.15
  ep_61_90:   base × 1.30
  ep_73:      base × 1.40   # PIVOT
  ep_90:      base × 1.45   # FINALE
  hard_cap:   0.85          # KHÔNG vượt — "crying" forbidden

# ============================================================
# DRIFT POLICY
# ============================================================

drift_policy:
  - voice_id swap giữa series → HARD-FAIL (brand identity 90 ep)
  - voice_signature checksum drift > 5% → REJECT
  - speech_rate drift > 0.02 → REJECT
  - pitch_semitones drift > 0.5 → WARNING
  - cross-passenger voice contamination → REJECT (vd ARCH_01 voice hiện ở ARCH_07)
  - intensity > 0.85 hard cap → REGEN (avoid "crying" drift)

# ============================================================
# QA INTEGRATION (TTS M12 MOS QA loads this)
# ============================================================

mos_target_per_voice:
  narrator: ≥4.3 naturalness / ≥4.5 intelligibility / ≥4.2 emotional_believability
  bac_tai: ≥4.4 naturalness / ≥4.5 intelligibility / ≥4.3 emotional_believability
  passenger_voices: ≥4.0 / ≥4.4 / ≥4.0 (lower threshold — one-shot)

blind_listen_test_passing_thresholds:
  Q1_brand_recognition_3s: ≥70%
  Q2_human_perception: ≥85%
  Q3_no_robot_segments: ≥80%
  Q4_want_to_continue: ≥75%
