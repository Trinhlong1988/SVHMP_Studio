# SVHMP — 15 VOICE BIBLE (round 14 — Mr.Long docx v6 19/6 17:14)
# Status: IMMUTABLE per series — voice = soul brand identity
# Loaded by: TTS Director M9 voice_bible (round 14) / Publisher P5 comment classifier (verify voice signature)
# Mục tiêu: lock cấu hình giọng từng character. Sai giọng = prompt 10/10 vẫn nghe dở.

version: 1.0
lock_date: 2026-06-19 17:30
purpose: |
  Phần quyết định thành bại của kênh KHÔNG nằm ở LUFS/ffmpeg/checksum
  mà nằm ở GIỌNG ĐỌC GỐC (voice actor + voice cloning quality).
  Voice Bible khóa cấu hình voice theo từng role để render nhất quán 90 ep.

# ============================================================
# NARRATOR (kể chuyện đêm khuya — soul brand)
# ============================================================

voice_bible:

  narrator:
    role: kể_chuyện_đêm_khuya
    target_persona: "60% người lớn tuổi kể chuyện đời / 25% MC đêm khuya / 15% khàn nhẹ người từng trải"

    demographic:
      gender: male
      age_impression: "50-55"
      regional_accent: neutral_northern   # Hà Nội chuẩn, không gắt
      vocal_health: warm_dark             # giọng ấm trầm, KHÔNG khàn rít

    technical_config:
      speech_rate: 0.88                   # khớp bible/01 + bible/05
      pitch_semitones: -1
      energy: 0.25                        # thấp — không kịch tính

    emotional_baseline:
      sadness: 0.45
      melancholy: 0.50
      mystery: 0.30
      horror: 0.10                        # CỰC THẤP — bible/01 fear_source = unsaid_words, KHÔNG ma
      warmth: 0.25
      authority: 0.40

    voice_clone_spec:
      # === ROUND 15 LOCKED v3.0 (19/6 17:49) — Mr.Long ship full pipeline spec ở Desktop\AN KHÁNH.md ===
      # Pipeline 4-LAYER (NOT 1-stage). Mr.Long script production-ready ở:
      #   C:\Users\Administrator\index-tts\narration_pipeline.py
      # Usage:
      #   cd C:\Users\Administrator\index-tts
      #   uv run --no-sync python narration_pipeline.py --input spec.json --output ep_NN.wav

      pipeline_version: "NNG_NARRATION_v3.0_LOCKED_19062026"
      reference_output_sample: "C:\\Users\\Administrator\\Desktop\\NNG_narration_profile_v3_regret_silences.wav"
      reference_size_mb: 1.72
      production_script: "C:\\Users\\Administrator\\index-tts\\narration_pipeline.py"
      input_format: JSON spec.json (sentences array với regret bool flag)
      output_format: 44100Hz mono PCM s16le WAV (NOT 48k/24bit — locked spec)

      layer_1_indextts2:
        engine: indextts2
        model_dir: checkpoints-vi (dinhthuan/index-tts-2-vietnamese)
        use_fp16: true
        spk_audio_prompt: "C:\\Users\\Administrator\\Downloads\\nng_out_1781850707426.wav"
        spk_audio_prompt_size_kb: 798
        emo_vector: [0.00, 0.00, 0.10, 0.20, 0.00, 0.35, 0.15, 0.15]
        emo_vector_order: [happy, angry, sad, afraid, disgusted, melancholic, surprised, calm]
        emo_vector_mapping:
          curiosity_0_15: surprised 0.15
          unease_0_20: afraid 0.20
          empathy_0_25: sad 0.10 + calm 0.15
          regret_0_35: melancholic 0.35 (dominant)
        emo_alpha: 1.0
        interval_silence_intra_segment_ms: 200
        per_sentence_generation: true   # NOT one-shot whole text

      layer_2_silence_concat:
        sentence_end_ms: 450        # giữa câu thường
        regret_before_ms: 1200      # trước câu tiếc nuối (next sentence is regret)
        regret_after_ms: 1800       # sau câu tiếc nuối (current sentence is regret)
        ending_silence_ms: 3000     # sau câu cuối cùng tập

      layer_3_rvc_nng:
        engine: rvc-vn
        rvc_dir: "D:\\rvc-vn"
        rvc_python: "D:\\rvc-vn\\.venv\\Scripts\\python.exe"
        model_name: "NNG.pth"
        index_path: "D:\\rvc-vn\\logs\\NNG\\added_IVF5704_Flat_nprobe_1_NNG_v2.index"
        f0method: rmvpe
        f0up_key: -1 semitone
        index_rate: 0.90
        rms_mix_rate: 0.20
        protect: 0.40

      layer_4_ffmpeg_master:
        chain: |
          asetrate=38861,                                          # = 40000 × 2^(-0.5/12) (pitch -0.5 semitone)
          atempo=0.94701,                                          # = 0.92 / 0.97153 (tempo 0.92 sau pitch shift)
          aresample=44100,                                         # resample về 44100
          bass=g=1.5:f=200,                                        # warmth +15%
          treble=g=-1:f=8000,                                      # darkness +10%
          equalizer=f=2500:width_type=q:width=2:g=-0.5,            # huskiness +5% (cắt presence)
          acompressor=threshold=-18dB:ratio=2:attack=20:release=200, # compression 2:1
          loudnorm=I=-16:TP=-1.5:LRA=11                            # LUFS -16 broadcast
        cumulative_pitch_shift: -1.5 semitone (RVC -1 + ffmpeg -0.5)
        cumulative_tempo: 0.92 (effective speech rate)
        output_sr: 44100
        output_format: pcm_s16le mono

      voice_profile_target:
        gender: male
        age_impression: "50-55"
        timbre:
          warmth: "+15%"
          darkness: "+10%"
          huskiness: "+5%"
        speech:
          speed: 0.92
          energy: "-15%"
          expressiveness: "+20%"
        pitch: -1.5 semitone
        compression: "2:1"
        loudness: "LUFS -16, TP -1.5, LRA 11"

      cost_per_ep: $0 (local GPU RTX 5060 Ti 16GB)
      latency_estimate_per_ep: "13-15 min cho ~236 sentence Ep01 (= IndexTTS2 ~12min + concat 5s + RVC 30s + ffmpeg 10s)"

      spec_json_schema:
        sentences:
          - text: string
            regret: boolean   # true → trigger regret_before/regret_after silence rules
        sample_prompt: string (optional override default)

      regret_flag_heuristic_for_generator:
        # Generator/QA Lock flag regret=true cho câu nào trong beat_4 PHẦN 3:
        - "Tôi nhớ ra rồi…"
        - "Tôi đã không [verb]"
        - "Tôi không [verb] kịp"
        - "Tôi không [verb] được"
        - "Tôi sợ [verb]"
        - "Tám năm [verb không]"
        - "Trớ trêu thay"
        - "Thì ra"
        - "câu chưa kịp nói"
        - "không kịp về"
        - "không bao giờ"
        - "không quay lại"
        - "Là lúc [tên] [động từ chết/đi]"

      voice_signature_checksum: PLACEHOLDER  # compute từ first ep render Ep01

      voice_prompt_sample:
        # === SHIPPED 19/6 14:09 by Mr.Long — INPUT voice prompt cho IndexTTS2 zero-shot clone ===
        # Mr.Long flow: drop file này vào IndexTTS2 PHASE 1 (Tab "🎤 PHASE 2" SET MẪU) →
        # PHASE 1 fill prompt_audio → IndexTTS2 generate narration giống tone NNG
        # KHÔNG dùng RVC 2-stage convert nữa — IndexTTS2 với voice_prompt là đủ.
        file_path: "C:\\Users\\Administrator\\Desktop\\NNG_narration_sample_19062026.wav"
        duration_s: 13.52
        channels: mono
        sample_rate_hz: 40000      # IndexTTS2 chấp nhận đa rate — không cần preprocess
        bit_depth: 16
        size_mb: 1.08
        usage:
          - PRIMARY: IndexTTS2 voice_prompt input (prompt_audio field)
          - SECONDARY (optional): emo_audio_prompt cùng file (extract emotion tone)
          - QA reference: M13 blind_listen Q1 brand recognition (so sánh output vs sample)
        upload_to_indextts2_webui:
          port: 7861
          tab: "🎤 PHASE 2 — SET MẪU"
          field: prompt_audio
          persistence: drop 1 lần đầu mỗi session, hoặc lưu vào checkpoints-vi config
        immutable: true            # KHÔNG replace sample giữa series — drift voice = HARD-FAIL
        notes: "Output target M5 vẫn là 48kHz 24-bit. IndexTTS2 generate ở 16-24kHz tùy model, ffmpeg upsample cuối."

      provider_fallback_1:
        name: "IndexTTS2 local raw (skip RVC convert)"
        use_when: "RVC server down OR voice convert fails QA"
        port: 7861
        model_dir: "checkpoints-vi (dinhthuan/index-tts-2-vietnamese)"
        MOS_gap_vs_NNG: "~0.5 (lower — không có signature warm-dark)"

      provider_fallback_2:
        name: "ElevenLabs cloud (last resort)"
        use_when: "cả NNG và IndexTTS2 fail"
        voice_id: TODO_clone_30s_if_ever_needed
        cost: "$2.50/ep"
        warning: "Brand signature drift — không khớp NNG signature"

    qa_target_perception:
      first_2s_recognizable: true        # nghe 2s đầu phải nhận ra brand
      mistaken_for_actual_narrator_human: ">70% blind test (per docx v6 Blind Listen Test)"
      mistaken_for_NNG_original: ">60% (homage threshold — không cần 100% giống NNG)"
      not_robotic_perception: ">85%"
      emotional_believability_MOS: "≥4.2"
      RVC_signature_consistency_90_ep: "≥0.95 cosine similarity"

  bac_tai:
    role: tài_xế_xe_khách
    target_persona: "gentle authoritative weary — patient infinite, tired but never angry"

    demographic:
      gender: male
      age_impression: "55-60"
      regional_accent: neutral_northern (slight rural touch)
      vocal_health: warm_low (chậm hơn narrator)

    technical_config:
      speech_rate: 0.83                   # CHẬM hơn narrator
      pitch_semitones: -2                 # TRẦM hơn narrator
      energy: 0.20                        # gần flat

    emotional_baseline:
      sadness: 0.35
      melancholy: 0.30
      mystery: 0.40
      horror: 0.00                        # ZERO
      warmth: 0.30
      authority: 0.60                     # cao — bác tài là rule-keeper
      patience: 1.00                      # vô tận

    speech_lines_locked:
      - "Con đã nhớ ra chưa?"
      - "Chưa tới lúc."

    cue_per_line:
      "Con đã nhớ ra chưa?":
        intonation: "xuống thấp dần, hỏi nhưng KHÔNG cao giọng cuối"
        pause_before_ms: 1500
        pause_after_ms: 800
        breath_before: true (chậm)

      "Chưa tới lúc.":
        intonation: "flat hoàn toàn, dứt khoát nhưng không khô"
        pause_before_ms: 1200
        pause_after_ms: 1500             # nặng hơn — báo hiệu chuyển scene
        breath_before: true (chậm)

    voice_clone_spec:
      reference_duration_s: 30 (2 câu chuẩn × 5-10 lần intonation khác nhau)
      provider_primary: ElevenLabs
      voice_id: PLACEHOLDER_CLONE_BAC_TAI_SEPARATE  # KHÁC narrator
      voice_signature_checksum: PLACEHOLDER
      drift_policy: HARD-FAIL nếu voice_id swap với narrator giữa ep

    qa_target_perception:
      first_2_words_recognizable_as_bac_tai: true
      cross_ep_consistency_similarity: ≥0.95 (CLIP / cosine voice)

# ============================================================
